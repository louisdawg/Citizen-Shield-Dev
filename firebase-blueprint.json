{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Citizen Shield platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "email": { "type": "string", "description": "The user's email address." }
      },
      "required": ["uid", "displayName"]
    },
    "Message": {
      "title": "Message",
      "description": "A real-time message sent in a regional chat.",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the message." },
        "authorId": { "type": "string", "description": "The UID of the author." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "authorPhoto": { "type": "string", "description": "The photo URL of the author." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "region": { "type": "string", "description": "The region this message belongs to." }
      },
      "required": ["text", "authorId", "authorName", "timestamp", "region"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/chats/{regionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a specific regional chat."
    }
  }
}
